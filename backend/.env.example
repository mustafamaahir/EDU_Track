# Transaction pooler URL (IPv4-only) — from Supabase Dashboard → Settings → Database → Connection Pooling
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:[YOUR-PASSWORD]@aws-1-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true

# JWT — use a long random string in production
JWT_SECRET=change-this-to-a-long-random-secret
